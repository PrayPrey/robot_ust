# LLM Robot Control System - Environment Configuration Template
# Story 3.2: FastAPI Web Control Server - Task 11
#
# Copy this file to .env and fill in your actual values:
# cp .env.template .env
#
# IMPORTANT: Never commit .env file to version control!
# The .env file contains sensitive information like API keys.

# ============================================================================
# OpenAI API Configuration (REQUIRED)
# ============================================================================

# OpenAI API key for Planner and Actor agents (GPT-4o-mini)
# Get your key from: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI model to use (default: gpt-4o-mini)
# Options: gpt-4o-mini, gpt-4o, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4o-mini

# ============================================================================
# Webots Simulation Configuration (REQUIRED)
# ============================================================================

# Path to Webots installation directory
# Windows example: C:\Program Files\Webots
# Linux example: /usr/local/webots
# macOS example: /Applications/Webots.app
WEBOTS_PATH=C:\Program Files\Webots

# Webots world file to load (relative to project root)
WEBOTS_WORLD=worlds/robot_world.wbt

# ============================================================================
# FastAPI Web Server Configuration (REQUIRED for Story 3.2)
# ============================================================================

# Server host address
# Development: 127.0.0.1 (localhost only, recommended for dev)
# Production: 0.0.0.0 (all interfaces, required for external access)
SERVER_HOST=127.0.0.1

# Server port (default: 8000)
# Make sure this port is not in use by another application
# Firewall: Allow this port for production deployment
SERVER_PORT=8000

# Number of uvicorn worker processes (production only)
# Recommended: Number of CPU cores
# Development mode ignores this setting (uses 1 worker with auto-reload)
WORKERS=4

# Log level for web server
# Options: debug, info, warning, error, critical
# Development: debug or info
# Production: info or warning
LOG_LEVEL=info

# ============================================================================
# Ollama Configuration (REQUIRED for Story 3.1 - Reactive Controller)
# ============================================================================

# Ollama API base URL (default: http://localhost:11434)
# Change if Ollama is running on a different host/port
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model for reactive controller (default: tinyllama)
# Must be pulled first: ollama pull tinyllama
# Options: tinyllama, llama2, mistral, phi
OLLAMA_MODEL=tinyllama

# Ollama request timeout in seconds (default: 2.0)
# Lower values fail faster, higher values allow more time for inference
OLLAMA_TIMEOUT=2.0

# ============================================================================
# ChromaDB RAG Configuration (REQUIRED for Story 2.1)
# ============================================================================

# ChromaDB persistent storage path (relative to project root)
# Leave empty for in-memory database (not recommended for production)
CHROMADB_PATH=data/chroma_db

# ChromaDB collection name for mission knowledge base
CHROMADB_COLLECTION=mission_knowledge

# OpenAI embedding model for RAG (default: text-embedding-3-small)
# Options: text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002
EMBEDDING_MODEL=text-embedding-3-small

# Number of RAG results to retrieve for planning context (default: 3)
# Higher values provide more context but increase LLM prompt size
RAG_TOP_K=3

# ============================================================================
# Safety and Performance Configuration
# ============================================================================

# Mission timeout in seconds (default: 30)
# Maximum time allowed for a single mission execution
MISSION_TIMEOUT=30

# Max retry attempts for failed missions (default: 3)
# Number of automatic replanning attempts on mission failure
MAX_RETRIES=3

# Minimum battery level for mission execution (default: 20)
# Abort mission if robot battery drops below this percentage
MIN_BATTERY_LEVEL=20

# Reactive controller check interval in milliseconds (default: 64)
# How often to check for obstacles during action execution
REACTIVE_CHECK_INTERVAL_MS=64

# Status broadcast frequency in milliseconds (default: 100, 10Hz)
# How often to send robot status updates via WebSocket
STATUS_BROADCAST_INTERVAL_MS=100

# ============================================================================
# Logging Configuration
# ============================================================================

# Log directory (relative to project root)
LOG_DIR=logs

# Log file name pattern (default: mission_{timestamp}.log)
# {timestamp} will be replaced with current datetime
LOG_FILE_PATTERN=mission_{timestamp}.log

# Enable JSON logging (default: true)
# Structured logs for easier parsing and analysis
ENABLE_JSON_LOGS=true

# Enable OpenLit LLM monitoring (default: true)
# Track LLM calls, costs, and performance
ENABLE_OPENLIT=true

# ============================================================================
# Development vs Production Settings
# ============================================================================

# Environment mode: development or production
# Affects logging verbosity, auto-reload, and security settings
ENVIRONMENT=development

# Enable FastAPI debug mode (default: true for development)
# Shows detailed error messages and auto-reloads on code changes
DEBUG=true

# Enable CORS for frontend development (default: true)
# Allow requests from React dev server (localhost:3000)
ENABLE_CORS=true

# ============================================================================
# Optional: Database Configuration (Future Use)
# ============================================================================

# PostgreSQL database URL (not used in current version)
# Format: postgresql://user:password@host:port/database
# DATABASE_URL=postgresql://user:password@localhost:5432/llm_robot

# Redis URL for caching (not used in current version)
# Format: redis://host:port/db
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# Security (Production Only)
# ============================================================================

# Secret key for session encryption (generate with: openssl rand -hex 32)
# IMPORTANT: Change this in production!
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# Enable SSL/TLS for web server (default: false)
# Requires SSL certificate and key files
ENABLE_SSL=false

# SSL certificate file path (required if ENABLE_SSL=true)
# SSL_CERT_FILE=/path/to/cert.pem

# SSL key file path (required if ENABLE_SSL=true)
# SSL_KEY_FILE=/path/to/key.pem

# Enable API authentication (not implemented in current version)
# ENABLE_AUTH=false

# ============================================================================
# Notes
# ============================================================================

# 1. All paths can be absolute or relative to project root
# 2. Boolean values: true or false (lowercase)
# 3. Numeric values: integers or floats without quotes
# 4. String values: with or without quotes
# 5. Comments: lines starting with # are ignored

