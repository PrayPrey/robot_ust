# LLM Robot Control System - Example Environment Configuration
# This file shows sample values for development environment.
# Copy .env.template to .env and customize for your setup.

# OpenAI Configuration
OPENAI_API_KEY=sk-proj-1234567890abcdef  # Replace with your actual key
OPENAI_MODEL=gpt-4o-mini

# Webots Configuration
WEBOTS_PATH=C:\Program Files\Webots
WEBOTS_WORLD=worlds/robot_world.wbt

# Web Server Configuration (Development)
SERVER_HOST=127.0.0.1
SERVER_PORT=8000
WORKERS=4
LOG_LEVEL=info

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama
OLLAMA_TIMEOUT=2.0

# ChromaDB RAG Configuration
CHROMADB_PATH=data/chroma_db
CHROMADB_COLLECTION=mission_knowledge
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=3

# Safety and Performance
MISSION_TIMEOUT=30
MAX_RETRIES=3
MIN_BATTERY_LEVEL=20
REACTIVE_CHECK_INTERVAL_MS=64
STATUS_BROADCAST_INTERVAL_MS=100

# Logging
LOG_DIR=logs
LOG_FILE_PATTERN=mission_{timestamp}.log
ENABLE_JSON_LOGS=true
ENABLE_OPENLIT=true

# Development Settings
ENVIRONMENT=development
DEBUG=true
ENABLE_CORS=true

# Security (Development - NOT FOR PRODUCTION)
SECRET_KEY=dev_secret_key_change_in_production
ENABLE_SSL=false
